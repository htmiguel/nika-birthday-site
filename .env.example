# Copy to .env.local (never commit .env.local) — or sync from Vercel:
#
#   npm run env:pull
#
# That pulls Production env from the linked project (htmiguels-projects / nika)
# into .env.local, including Neon + Blob from the dashboard.

# --- Postgres (Neon) — app reads the first one that is set ---
# Vercel/Neon may set DATABASE_URL, POSTGRES_URL, and/or POSTGRES_PRISMA_URL.
DATABASE_URL=
# POSTGRES_URL=
# POSTGRES_PRISMA_URL=

# --- Vercel Blob — app reads BLOB_READ_WRITE_TOKEN or VERCEL_BLOB_READ_WRITE_TOKEN ---
BLOB_READ_WRITE_TOKEN=
# VERCEL_BLOB_READ_WRITE_TOKEN=

# --- Admin: https://YOUR_DOMAIN/nika/admin?secret=YOUR_VALUE (8+ chars) ---
NIKA_ADMIN_SECRET=

# --- Optional: local Postgres instead of Neon (docker-compose) ---
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/birthday
