# Postgres: Neon / Vercel in production, or local Docker (see docker-compose.yml).
# Vercel may expose DATABASE_URL and/or POSTGRES_URL — the app accepts either.
# Local: docker compose up -d, then:
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/birthday
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# Vercel Blob — created when you add the Blob store to the project.
# Optional locally: omit during `next dev` and uploads go to public/dev-media/ (gitignored).
BLOB_READ_WRITE_TOKEN=

# Admin-only: visit /nika/admin?secret=YOUR_VALUE (8+ chars). Do not share the URL.
NIKA_ADMIN_SECRET=
